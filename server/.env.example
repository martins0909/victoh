# server/.env.example
# Copy to `server/.env` for local development.

# Server
PORT=5002
JWT_SECRET=your-jwt-secret-here
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Frontend base URL (used for CORS and to generate password reset links)
FRONTEND_URL=http://localhost:5173

# Resend (required to email password reset links in production)
# For development you can leave these blank; the server will log the reset link.
RESEND_API_KEY=
RESEND_FROM=

# Payments (optional, depending on what you use)
ECRS_SECRET_KEY=
PAYSTACK_SECRET=